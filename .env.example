# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Port for the keepalive HTTP server (Render sets this automatically, fallback is 3000)
PORT=3000

# Optional: channel ID to log ban actions to. Leave blank to disable.
LOG_CHANNEL_ID=

# Optional: how many recent messages per user to delete on offense (default 1)
MESSAGES_TO_DELETE=1
